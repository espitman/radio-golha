      "verses": [
        "بهررضایدوستگذشتیممازجان / آریبرایدوستزجانمی‌توانگذشت",
        "شفاعتگنهمراکهمی‌کندفردا / مگربهدامنآلودگاندرآویزم",
        "بهرقتلمبهانه‌ایبهترنیست / ازاینکهزنده‌امبی‌تو"
      ],
      "poet": "شاه بیگم ضیاء",
      "style": ""
    },
    {
      "speaker": "",
      "verses": [
        "اگر به باد دهی زلف عنبر آسا را / به دام خویش کشی آهوان صحرا را",
        "اگر زلطف نظر افکنی به عزم / رمیمدوباره زنده کمی معجزه مسیحا را"
      ],
      "poet": "شاه بیگم ضیاء",
      "style": "غزل"
    },
    {
      "speaker": "",
      "verses": [
        "بهر رضای دوست گذشتیم ما زجان / آری برای دوست زجان می‌توان گذشت"
      ],
      "poet": "شاه بیگم ضیاء",
      "style": "غزل"
    }
  ]
