  "segments": [
    {
      "speaker": "روشنک",
      "verses": [
        "چشم بگشا که جلوه دلدار / به تجلی است از درودیوار",
        "این تماشا چوبنگری گویی / لیس فی الدارغیره دیار"
      ],
      "poet": "منسوب به عطار",
      "style": "قصیده"
    },
    {
      "speaker": "روشنک",
      "verses": [
        "گرچهمستیموخرابیمچوشب‌هایدگر / بازكنساقیمجلسسرمینایدگر",
        "امشبیراكهدرآنیمغنیمتشمریم / شایدایجاننرسیدیمبهفردایدگر",
        "مستمستممشكنقدرخودایپنجهٔغم / منبهمیخانه‌امامشبتوبروجایدگر"
      ],
      "poet": "عماد خراسانی",
      "style": "غزل"
    },
    {
      "speaker": "روشنک",
      "verses": [
        "دوستتدارمودانمكهتوییدشمنجانم / ازچهبادشمنجانمشده‌امدوستندانم",
        "مرغكانچمنیراستبهاریوخزانی / منكهدرداماسیرمچهبهارمچهخزانم",
        "گریهازمردمهشیارخلایقنپسندند / شده‌اممستكهتاقطرهٔاشكیبفشانم"
      ],
      "poet": "عماد خراسانی",
      "style": "غزل"
    },
    {
      "speaker": "حسین قوامی",
      "verses": [
        "شبفراقكهداندكهتاسحرچنداست / مگركسیكهبهزندانعشقدربنداست",
        "گرفتمازغمدلراهبوستانگیرم / كدامسروبهبالایدوستماننداست",
        "پیاممنكهرساندبهیارمهرگسل / كهبرشكستیوماراهنوزپیونداست",
        "قسمبهجانتوخوردنطريقعزتنيست / بهخاكپایتوكانهمعظيمسوگنداست",
        "كهباشكستنپيمانوبرگرفتندل / هنوزديدهبهديدارتآرزومنداست"
      ],
      "poet": "سعدی",
      "style": "غزل"
    },
    {
      "speaker": "روشنک",
      "verses": [
        "زيبدكهزدرگاهتنوميدنگرددباز / آنكسكهبهاميدیبرخاكدرتافتد"
      ],
      "poet": "غزل",
      "style": "عراقی"
    }
  ]
}