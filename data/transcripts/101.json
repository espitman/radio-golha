  "segments": [
    {
      "speaker": "روشنک",
      "verses": [
        "چشمبگشاکهجلوهدلدار / بهتجلیاستازدرودیوار",
        "اینتماشاچوبنگریگویی / لیسفیالدارغیرهدیار"
      ],
      "poet": "منسوب به عطار",
      "style": "قصیده"
    },
    {
      "speaker": "روشنک",
      "verses": [
        "مادرخلوتبهرویخلقببستیم / ازهمهبازآمدیموباتونشستیم",
        "آنچهنهپیوندیاربودبریدیم / وانچهنهپیماندوستبودشكستیم",
        "مردمهشیارازاینمعاملهدورند / شایداگرعیبماكنندكهمستیم",
        "شاكرنعمتبههرطریقكهبودیم / داعیدولتبههرمقامكههستیم",
        "ایبتصاحبدلانمشاهدهبنمای / تاتوببینیموخویشتننپرستیم",
        "دیدهنگهداشتیمتانروددل / باهمهعیاریازكمندنجستیم",
        "تاتواشارتكنیكهدرقدممریز / جانگرامینهادهبركفدستیم"
      ],
      "poet": "سعدی",
      "style": "غزل"
    },
    {
      "speaker": "محمودی خوانساری",
      "verses": [
        "شبیارمنتباستوغمسینهسوزهم / تنهانهشبدرآتشمایگلكهروزهم",
        "ایاشكهمتیكهبهكِشتوجودِمن / آتشفكندآهودلسینهسوزهم",
        "گفتمكهباتوشمعطربتابناكنیست / گفتاكهسیمگونمهِگیتیفروزهم",
        "گفتمكهبعدازآنهمهدل‌هاكهسوختی / كسمی‌خوردفریبتوگفتاهنوزهم",
        "ایغممگرتویارشویورنهبارهی / دلدشمناستوآنصنمِدلفروزهم"
      ],
      "poet": "رهی معیری",
      "style": "غزل"
    },
    {
      "speaker": "روشنک",
      "verses": [
        "زیبدكهزدرگاهتنومیدنگرددباز / آن‌كسكهبهامیدیبرخاكدرتافتد"
      ],
      "poet": "عراقی",
      "style": "غزل"
    }
  ]
