    {
      "speaker": "روشنک",
      "verses": [
        "چشمبگشاكهجلوهٔدلدار / بهتجلیاستازدرودیوار",
        "اینتماشاچوبنگریگویی / لیسفی‌الدارغیرهُدیّار"
      ],
      "poet": "منسوب به عطار",
      "style": "قصیده"
    },
    {
      "speaker": "روشنک",
      "verses": [
        "امشبكهجمالتوطرحدگرافتادهاست / چینوشكنزلفتآشفته‌ترافتادهاست",
        "آشفتهوژولیدهسرگشتهوشوریده / پیچانوپریشیدهبریكدگرافتادهاست",
        "هیچینوشكنبینماززلفتودرهرسو / كاندرپییكدیگرزیروزبرافتادهاست",
        "یكامشبیكهتوییدربرابرمسرمست / گمانمبركهخبرازوجودخویشمهست",
        "قسمبهجانتوكزجانوازجهانبرخاست / هرآنكهیكنفسازرویعشقباتونشست",
        "نهاددلبهتووازهمهجهانبرداشت / گشاددربهتووبررُخدوعالمبست"
      ],
      "poet": "حبیب خراسانی",
      "style": "غزل"
    },
    {
      "speaker": "فرح",
      "verses": [
        "همهعمربرندارمسرازاینخمارمستی / كههنوزمننبودمكهتودردلمنشستی",
        "تونهمثلآفتابیكهحضوروغیبتافتد / دگرانروندوآیندوتوهمچنانكههستی",
        "چهحكایتازفراقتكهنداشتمولیكن / توكهرویبازكردیدرماجرایبستی",
        "دلدردمندماراكهاسیرتوستیارا / بهوصالمرهمینهچوبهانتظارخستی",
        "بروایفقیهدانابهخدایبخشمارا / تووزهدوپارساییمنوعاشقیومستی",
        "گلهازفراقیارانوجفایروزگاران / نهطریقتوستسعدیسرخویشگیرورستی"
      ],
      "poet": "سعدی",
      "style": "غزل"
    },
    {
      "speaker": "روشنک",
      "verses": [
        "امشبكهجمالتوطرحدگرافتادهاست / چینوشكنزلفتآشفته‌ترافتادهاست"
      ],
      "poet": "حبیب خراسانی",
      "style": "غزل"
    },
    {
