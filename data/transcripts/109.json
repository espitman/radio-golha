  "segments": [
    {
      "speaker": "روشنک",
      "verses": [
        "چشمبگشاکهجلوهدلدار / بهتجلیاستازدرودیوار",
        "اینتماشاچوبنگریگویی / لیسفیالدارغیرهدیار"
      ],
      "poet": "منسوب به عطار",
      "style": "قصیده"
    },
    {
      "speaker": "روشنک",
      "verses": [
        "دولتعشقبنازمكهزهردركهدرآید / روزنیبردلمازدرگهعزتبگشاید",
        "دیدهٔخاطرمامشرقومغربنشناسد / روشنازپرتومهریزهرسوكهبرآید",
        "بندهٔساقیحسنیمكهباگردشچشمی / همچوپیمانهٔمیزنگغمازدلبزداید",
        "تاببینیهمهزیباییورعناییساقی / باشتاجامنخستیندلتازكفبرباید"
      ],
      "poet": "ایزد",
      "style": "غزل"
    },
    {
      "speaker": "حسین قوامی",
      "verses": [
        "حالیامصلحتوقتدرآنمی‌بینم / كهكشمرختبهمیخانهوخوشبنشینم",
        "بسكهدرخرقهٔآلودهزدملافِصلاح / شرمسارازرُخساقیومیرنگینم",
        "جاممی‌گیرموازاهلِریادورشوم / یعنیازخلقِجهانپاكدلیبگزینم",
        "بردلمگردستم‌هاستخدایامپسند / كهمُكدرشودآیینهٔمِهرآیینم",
        "مناگررندخراباتموگرحافظِشهر / اینمتاعمكههمی‌بینیوكمترزینم"
      ],
      "poet": "حافظ",
      "style": "غزل"
    },
    {
      "speaker": "روشنک",
      "verses": [
        "شیوهٔخوشمنظرانچهرهنشاندادناست / پیشهٔاهلنظردیدنوجاندادناست",
        "شاهدشیرینلبمبوسهنهانمی‌دهد / آریرسمپریبوسهنهاندادناست"
      ],
      "poet": "فروغی بسطامی",
      "style": "غزل"
    },
    {
      "speaker": "روشنک",
      "verses": [
        "زیبدكهزدرگاهتنومیدنگرددبا / آن‌كسكهبهامیدیبرخاكدرتافتد"
      ],
      "poet": "عراقی",
      "style": "غزل"
    }
  ]
}