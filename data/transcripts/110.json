  "segments": [
    {
      "speaker": "روشنک",
      "verses": [
        "چشمبگشاکهجلوهدلدار / بهتجلیاستازدرودیوار",
        "اینتماشاچوبنگریگویی / لیسفیالدارغیرهدیار"
      ],
      "poet": "منسوب به عطار",
      "style": "قصیده"
    },
    {
      "speaker": "روشنک",
      "verses": [
        "عقلسودازدهدرسوزوگدازاستهنوز / یارپیمانشكنمبرسرنازاستهنوز",
        "گرچهبستنددرصومعهومسجدودیر / شكردارمكهدرمیكدهبازاستهنوز",
        "مابدانقامتوبالانگرانی‌امهنوز / وزغمتخوندلازدیدهروانی‌امهنوز",
        "جزتویارینگرفتیمونخواهیمگرفت / برهمانعهدكهبودیمبرآنیمهنوز",
        "بهامیدتوشبخویشتنآریمبهروز / آنجفادیدهكهبودیمهمانیمهنوز",
        "ایدریغاكهپسازآنهمهجانبازی‌ها / برسركویتوبی‌نامونشانیمهنوز",
        "دیگرانوادیعشقتوبهپایانبردند / مابهیادتودرایندشتدوانیمهنوز",
        "آرمیدندهمهدرحرمحرمتوما / ساكنكویخراباتمغانیمهنوز",
        "نوبهارآمدوبگذشتولیكنمنودل / همچناندرتبآسیبخزانیمهنوز",
        "ماازاینچرخكهنگرچهبسیپیرتریم / همچنانازمددعشقجوانیمهنوز",
        "اوستادهمهفنبودهوهستیمادیب / باهمانناموهمانشوكتوشأنیمهنوز"
      ],
      "poet": "ادیب نیشابوری",
      "style": "غزل"
    },
    {
      "speaker": "قوامی",
      "verses": [
        "بگذشتچوننسیمبهاریجوانیم / طیشدچوعمر لالهوگلزندگانیم",
        "نامهربانشوایدلخونینكهدرجهان / شدخصمزندگانیمنمهربانیم",
        "ایبهترازجوانیوایخوش‌ترازامید / بگذشتدرامیدوصالتجوانیم",
        "منسودچونغباروتوهرسویچوننسیم / دامنبهنازمی‌كشیومی‌كشانیم",
        "تاكیبهیزمغیربدانرویآتشین / بنشینیوبرآتشحسرتنشانیم"
      ],
      "poet": "علی صدارت",
      "style": "غزل"
    },
    {
      "speaker": "روشنک",
      "verses": [
        "زیبدكهزدرگاهتنومیدنگرددباز / آن‌كسكهبهامیدیبرخاكدرتافتد"
      ],
      "poet": "عراقی",
      "style": "غزل"
    }
  ]
