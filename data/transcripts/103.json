  "segments": [
    {
      "speaker": "روشنک",
      "verses": [
        "چشمبگشاکهجلوهدلدار / بهتجلیاستازدرودیوار",
        "اینتماشاچوبنگریگویی / لیسفیالدارغیرهدیار"
      ],
      "poet": "منسوب به عطار",
      "style": "قصیده"
    },
    {
      "speaker": "روشنک",
      "verses": [
        "عاشقكهچراغآشناییافروخت / دررویتودیدودیدهازعالمدوخت",
        "می‌رفتوفسانهٔمحبتمی‌خواند / می‌مُردوبهدیگرانوفامی‌آموخت"
      ],
      "poet": "عاشق اصفهانی",
      "style": "غزل"
    },
    {
      "speaker": "روشنک",
      "verses": [
        "بریختدُردِمیومحتسبزدیرگذشت / رسیدهبودبلاییولیبهخیرگذشت",
        "نهالقدتوراجلوه‌گرنمی‌خواهم / درآندیاركهروزینسیمغیرگذشت"
      ],
      "poet": "آصفی هروی",
      "style": "دوبیتی"
    },
    {
      "speaker": "روشنک",
      "verses": [
        "مادستشوقباتودرآغوشكرده‌ایم / بازآكهازگذشتهفراموشكرده‌ایم",
        "ازمامپرسحالدلماكهیكنفس / خودرابهحیلهپیشتوخاموشكرده‌ایم"
      ],
      "poet": "فتحی اردستانی",
      "style": "دوبیتی"
    },
    {
      "speaker": "روشنک",
      "verses": [
        "ایناصبوردلبهخدامی‌سپارمت / وزكوییارمی‌رومومی‌گدازمت",
        "ازبسبهعهددوستی‌‌اتاعتمادنیست / یارمنیویاركسانمی‌شمارمت"
      ],
      "poet": "عاشق اصفهانی",
      "style": "غزل"
    },
    {
      "speaker": "گلپایگانی",
      "verses": [
        "ماهمشكستهخاطرودیوانهبوده‌ایم / ماهماسیرطرهٔجانانهبوده‌ایم",
        "مانیزچوننسیمسحردرحریمباغ / روزیندیمیلبلوپروانهبوده‌ایم",
        "ماهمبهروزگارجوانیزشورعشق / عبرتفزایمردمفرزانهبوده‌ایم",
        "بركامخشكمابهحقارتنظرمكن / ماهمرفیقساغروپیمانهبوده‌ایم",
        "ایعاقلانبهلذتدیوانگیقسم / مانیزدلشكستهودیوانهبوده‌ایم",
        "ماهمشكستهخاطرودیوانهبوده‌ایم / ماهماسیرطرهٔجانانهبوده‌ایم"
      ],
      "poet": "پژمان بختیاری",
      "style": "غزل"
    },
    {
      "speaker": "روشنک",
      "verses": [
        "زیبدكهزدرگاهتنومیدنگرددباز / آن‌كسكهبهامیدیبرخاكدرتافتد"
      ],
      "poet": "عراقی",
      "style": "غزل"
    }
  ]
